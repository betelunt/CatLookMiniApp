<!-- 协议模板下载 -->
<view class="container">
  <view class="card" style="text-align:center;">
    <image style="width:64rpx;height:64rpx;display:block;margin:0 auto 20rpx;" src="/images/icons/agreement.png" mode="aspectFit"></image>
    <text class="title">领养协议模板</text>
    <text class="desc" style="margin:20rpx 0;display:block;">
      猫录官方领养协议模板（PDF 格式）。<br/>
      下载后双方填写信息并线下签署。<br/>
      签署完成后可在本小程序回传存档。
    </text>
    <button class="btn-primary" bindtap="onDownload" loading="{{downloading}}">
      下载领养协议
    </button>
  </view>
</view>
