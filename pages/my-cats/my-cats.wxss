.top-bar {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 24rpx;
}
.title { font-size: 34rpx; font-weight: 700; }
.add-btn {
  background: var(--primary); color: #FFF;
  padding: 12rpx 28rpx; border-radius: 30rpx; font-size: 26rpx;
}
.cat-item { display: flex; justify-content: space-between; align-items: center; gap: 16rpx; }
.my-cat-thumb {
  width: 100rpx; height: 100rpx; border-radius: 12rpx; flex-shrink: 0;
}
.my-cat-thumb.placeholder {
  display: flex; align-items: center; justify-content: center;
  background: #FFF5EC; font-size: 48rpx;
}
.cat-info { flex: 1; }
.cat-name { font-size: 30rpx; font-weight: 600; display: block; margin-bottom: 6rpx; }
.cat-tags { display: flex; gap: 12rpx; flex-wrap: wrap; font-size: 24rpx; color: var(--text-secondary); margin-bottom: 4rpx; }
.status-tag { font-weight: 600; }
.meta { color: var(--text-secondary); }
.seeking-badge {
  display: inline-block; background: #FFF3E0; color: #E65100;
  padding: 2rpx 12rpx; border-radius: 6rpx; font-size: 20rpx; margin-top: 4rpx;
}
.cat-actions { display: flex; gap: 16rpx; align-items: center; flex-shrink: 0; }
.action-icon { width: 36rpx; height: 36rpx; padding: 4rpx; }
.action-icon.delete { opacity: 0.6; }

.adoption-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  line-height: 1;
  padding: 3rpx 14rpx;
  border-radius: 30rpx;
  border: 1.5rpx solid var(--primary);
  color: var(--primary);
  font-weight: 500;
  white-space: nowrap;
}
.adoption-toggle.cancel {
  border-color: #E65100;
  color: #E65100;
  background: #FFF3E0;
}
