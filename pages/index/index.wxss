/* ── 猫咪广场 — 双列瀑布流 ── */

/* 瀑布流容器 */
.waterfall {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}
.col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 顶部栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.title { font-size: 34rpx; font-weight: 700; }

/* ── 筛选栏 ── */
.filter-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.filter-pill {
  flex: 1;
  background: var(--card);
  padding: 16rpx 12rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.filter-pill.active {
  background: #FFF3E0;
  color: #E65100;
  font-weight: 600;
}
.search-box {
  flex: 2;
  position: relative;
  display: flex;
  align-items: center;
}
.search-prefix-icon {
  position: absolute;
  left: 18rpx;
  width: 32rpx;
  height: 32rpx;
  z-index: 1;
}
.search-input {
  width: 100%;
  background: var(--card);
  padding: 16rpx 20rpx 16rpx 58rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

/* 激活标签行 */
.active-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}
.tag-chip {
  background: #FFF3E0;
  color: #E65100;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

/* 竖卡 */
.archive-card {
  padding: 0;
  overflow: hidden;
}
.waterfall-card {
  min-height: 240rpx;
}

/* 档案编号（照片下方） */
.card-archive-code {
  padding: 10rpx 20rpx;
  font-size: 20rpx;
  color: var(--text-secondary);
  background: #F8F8F8;
  text-align: center;
  letter-spacing: 2rpx;
  font-family: monospace;
}

/* 照片区 — 保留原始比例，自然瀑布流错位 */
.card-photo {
  width: 100%;
  display: block;
  min-height: 200rpx;
}
.card-photo-placeholder {
  width: 100%;
  aspect-ratio: 1 / 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  background: #FFF5EC;
}

/* 信息区 */
.card-body {
  padding: 16rpx 20rpx;
}
.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}
.card-title-group {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  flex: 1;
  min-width: 0;
  overflow: hidden;
}
.card-name {
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.card-breed {
  font-size: 20rpx;
  color: var(--text-secondary);
  border: 1px solid #EEE;
  background: #FAFAFA;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.card-status-tag {
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  border: 1rpx solid #E0E0E0;
  background: #FAFAFA;
}

/* 加载更多 */
.load-more-hint {
  text-align: center;
  padding: 32rpx;
  color: #999;
  font-size: 24rpx;
}
