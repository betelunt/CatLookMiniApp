<!-- 猫咪广场 Tab1 — 浏览所有猫咪（只读） -->
<view class="container">
  <view class="top-bar">
    <text class="title">全部猫咪 ({{totalCount || (leftCats.length + rightCats.length)}})</text>
  </view>

  <!-- 筛选栏：城市 | 品种 | 搜索 -->
  <view class="filter-bar">
    <picker mode="selector" range="{{cities}}" bindchange="onCityChange">
      <view class="filter-pill {{cityFilter ? 'active' : ''}}">{{cityFilter || '城市'}} ▾</view>
    </picker>
    <picker mode="selector" range="{{breedOptions}}" bindchange="onBreedChange">
      <view class="filter-pill {{breedFilter ? 'active' : ''}}">{{breedFilter || '品种'}} ▾</view>
    </picker>
    <view class="search-box">
      <image class="search-prefix-icon" src="/images/icons/search.png" mode="aspectFit"></image>
      <input class="search-input" placeholder="搜索" value="{{searchKeyword}}" bindinput="onSearchInput" confirm-type="search" />
    </view>
  </view>

  <!-- 激活标签行 -->
  <view wx:if="{{cityFilter || breedFilter || searchKeyword}}" class="active-tags">
    <view wx:if="{{cityFilter}}" class="tag-chip" bindtap="clearFilter" data-key="cityFilter">{{cityFilter}} ✕</view>
    <view wx:if="{{breedFilter}}" class="tag-chip" bindtap="clearFilter" data-key="breedFilter">{{breedFilter}} ✕</view>
    <view wx:if="{{searchKeyword}}" class="tag-chip" bindtap="clearFilter" data-key="searchKeyword">"{{searchKeyword}}" ✕</view>
  </view>

  <!-- 加载骨架屏（双列） -->
  <view wx:if="{{loading}}" class="waterfall">
    <view class="col">
      <view class="skeleton card waterfall-card" wx:for="{{[1,3,5]}}" wx:key="*this"></view>
    </view>
    <view class="col">
      <view class="skeleton card waterfall-card" wx:for="{{[2,4]}}" wx:key="*this"></view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{leftCats.length === 0 && rightCats.length === 0}}" class="empty-state">
    <text style="font-size:80rpx;">📸</text>
    <text wx:if="{{cityFilter || breedFilter || searchKeyword}}">没有找到匹配的猫咪</text>
    <text wx:else>还没有猫咪照片，快来做第一只猫咪的守护者吧 🐱</text>
  </view>

  <!-- 瀑布流双列 -->
  <view wx:else class="waterfall">
    <view class="col">
      <view
        class="archive-card card waterfall-card"
        wx:for="{{leftCats}}" wx:key="id"
        data-id="{{item.id}}"
        bindtouchstart="onCardTouchStart"
        bindtouchmove="onCardTouchMove"
        bindtap="onCardTap"
      >
        <image wx:if="{{item.photo_url}}" class="card-photo" src="{{item.photo_url}}" mode="aspectFill" lazy-load="{{true}}" />
        <view wx:else class="card-photo-placeholder"><image style="width:60rpx;height:60rpx;" src="/images/icons/cat-default.jpg" mode="aspectFit"></image></view>
        <view wx:if="{{item.archive_code}}" class="card-archive-code">NO. {{item.archive_code}}</view>
        <view class="card-body">
          <view class="card-row">
            <view class="card-title-group">
              <text class="card-name">{{item.name}}</text>
              <text class="card-breed">{{item.breed || '待完善'}}</text>
            </view>
            <text class="card-status-tag" style="color:{{statusColors[item.health_status]}}">{{item.health_status || '未知'}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="col">
      <view
        class="archive-card card waterfall-card"
        wx:for="{{rightCats}}" wx:key="id"
        data-id="{{item.id}}"
        bindtouchstart="onCardTouchStart"
        bindtouchmove="onCardTouchMove"
        bindtap="onCardTap"
      >
        <image wx:if="{{item.photo_url}}" class="card-photo" src="{{item.photo_url}}" mode="aspectFill" lazy-load="{{true}}" />
        <view wx:else class="card-photo-placeholder"><image style="width:60rpx;height:60rpx;" src="/images/icons/cat-default.jpg" mode="aspectFit"></image></view>
        <view wx:if="{{item.archive_code}}" class="card-archive-code">NO. {{item.archive_code}}</view>
        <view class="card-body">
          <view class="card-row">
            <view class="card-title-group">
              <text class="card-name">{{item.name}}</text>
              <text class="card-breed">{{item.breed || '待完善'}}</text>
            </view>
            <text class="card-status-tag" style="color:{{statusColors[item.health_status]}}">{{item.health_status || '未知'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{!loading && loadingMore}}" class="load-more-hint">正在加载更多...</view>
  <view wx:elif="{{!loading && !hasMore && (leftCats.length + rightCats.length) > 0}}" class="load-more-hint">— 已显示全部猫咪 —</view>
</view>
