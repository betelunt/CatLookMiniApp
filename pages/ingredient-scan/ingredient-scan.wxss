/* ── 拍照识配料 ── */

.container {
  min-height: 100vh;
  background: #F8F8F8;
  padding: 32rpx 32rpx 0;
  display: flex;
  flex-direction: column;
}

/* ══════════════════════════════════════
   步骤指示器
   ══════════════════════════════════════ */
.steps {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 48rpx;
}
.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #DDD;
  transition: all 0.3s;
}
.step-dot.on {
  background: #FF8C42;
  width: 40rpx;
  border-radius: 8rpx;
}
.step-label {
  display: none;
}

/* ══════════════════════════════════════
   步骤一：拍照入口
   ══════════════════════════════════════ */
.camera-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 取景框 */
.viewfinder {
  width: 100%;
  height: 560rpx;
  background: #FFF;
  border-radius: 24rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 40rpx;
  overflow: hidden;
}

/* 四角引导线 */
.viewfinder::before,
.viewfinder::after {
  content: '';
  position: absolute;
  width: 48rpx;
  height: 48rpx;
  pointer-events: none;
}
/* 左上 */
.corner-tl {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  width: 48rpx;
  height: 48rpx;
  border-left: 4rpx solid #FF8C42;
  border-top: 4rpx solid #FF8C42;
  border-radius: 8rpx 0 0 0;
}
/* 右上 */
.corner-tr {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 48rpx;
  height: 48rpx;
  border-right: 4rpx solid #FF8C42;
  border-top: 4rpx solid #FF8C42;
  border-radius: 0 8rpx 0 0;
}
/* 左下 */
.corner-bl {
  position: absolute;
  bottom: 20rpx;
  left: 20rpx;
  width: 48rpx;
  height: 48rpx;
  border-left: 4rpx solid #FF8C42;
  border-bottom: 4rpx solid #FF8C42;
  border-radius: 0 0 0 8rpx;
}
/* 右下 */
.corner-br {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  width: 48rpx;
  height: 48rpx;
  border-right: 4rpx solid #FF8C42;
  border-bottom: 4rpx solid #FF8C42;
  border-radius: 0 0 8rpx 0;
}

.viewfinder-icon {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.8;
}
.viewfinder-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.viewfinder-hint {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
}

/* 按钮区 */
.camera-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  gap: 12rpx;
}

.btn-icon {
  width: 40rpx;
  height: 40rpx;
}

.btn-primary {
  background: #FF8C42;
  color: #FFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 66, 0.3);
}

.btn-outline {
  background: #FFF;
  color: #666;
  border: 2rpx solid #E0E0E0;
}

.or-divider {
  font-size: 26rpx;
  color: #CCC;
}

/* ══════════════════════════════════════
   步骤二：预览确认
   ══════════════════════════════════════ */
.preview-section {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* 图片卡片 */
.preview-card {
  background: #FFF;
  border-radius: 24rpx;
  padding: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 24rpx;
}
.preview-img {
  width: 100%;
  height: 520rpx;
  border-radius: 12rpx;
  display: block;
}

/* 状态 */
.preview-status {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 40rpx;
}
.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #4CAF50;
}
.status-text {
  font-size: 28rpx;
  color: #333;
}

/* 双按钮 */
.preview-actions {
  display: flex;
  gap: 20rpx;
}
.preview-actions .btn {
  flex: 1;
}

.btn-ghost {
  background: #FFF;
  color: #888;
  border: 2rpx solid #E0E0E0;
}

/* ══════════════════════════════════════
   步骤三：识别中
   ══════════════════════════════════════ */
.loading-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: -80rpx;
}

/* 扫描区域 */
.scan-area {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.scan-icon-bg {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.25;
}

/* 扫描线动画 */
.scan-line {
  position: absolute;
  left: 10%;
  width: 80%;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #FF8C42, transparent);
  border-radius: 2rpx;
  animation: scanMove 1.8s ease-in-out infinite;
  box-shadow: 0 0 16rpx rgba(255, 140, 66, 0.5);
}
@keyframes scanMove {
  0%   { top: 10%; opacity: 0; }
  20%  { opacity: 1; }
  80%  { opacity: 1; }
  100% { top: 90%; opacity: 0; }
}

/* 加载文字 */
.loading-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}
.loading-sub {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 48rpx;
}

/* 提示轮播 */
.tip-box {
  background: #FFF;
  border-radius: 16rpx;
  padding: 24rpx 36rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  max-width: 560rpx;
  text-align: center;
}
.tip-text {
  font-size: 24rpx;
  color: #888;
  transition: opacity 0.4s;
}

/* ══════════════════════════════════════
   通用
   ══════════════════════════════════════ */
.placeholder-spacer {
  flex: 1;
}
