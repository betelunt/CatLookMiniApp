<!-- 食物查询 Tab3 -->
<view class="container">
  <!-- 📷 拍照识配料入口 -->
  <view class="scan-entry card" bindtap="goScan">
    <view class="scan-entry-left">
      <view class="scan-icon-wrap">
        <image class="scan-icon-img" src="/images/icons/camera.png" mode="aspectFit"></image>
      </view>
      <view class="scan-entry-text">
        <text class="scan-entry-title">拍照识别配料表</text>
        <text class="scan-entry-sub">一拍即知，秒懂猫咪能不能吃</text>
      </view>
    </view>
    <text class="scan-entry-arrow">›</text>
  </view>

  <!-- 搜索框 -->
  <view class="search-box">
    <input class="search-input" placeholder="搜索食材名称..." value="{{searchText}}" bindinput="onSearch" />
    <image class="search-icon" src="/images/icons/search.png" mode="aspectFit"></image>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'food' ? 'active' : ''}}"
          data-tab="food" bindtap="onTabChange">
      <image style="width:32rpx;height:32rpx;vertical-align:middle;margin-right:4rpx;" src="/images/icons/search.png" mode="aspectFit"></image>食物查询
    </view>
    <view class="tab-item {{activeTab === 'nutrition' ? 'active' : ''}}"
          data-tab="nutrition" bindtap="onTabChange">
      <image style="width:32rpx;height:32rpx;vertical-align:middle;margin-right:4rpx;" src="/images/icons/supplement.png" mode="aspectFit"></image>营养知识
    </view>
  </view>

  <!-- ═══ 食物查询模式 ═══ -->
  <block wx:if="{{activeTab === 'food'}}">

  <!-- 分类标签 -->
  <scroll-view class="cat-scroll" scroll-x>
    <view class="cat-tag {{activeCategory === item.key ? 'active' : ''}}"
          wx:for="{{categories}}" wx:key="key"
          bindtap="onCategoryTap" data-category="{{item.key}}">
      {{item.label}}
    </view>
  </scroll-view>

  <!-- 加载态 -->
  <view wx:if="{{loading}}">
    <view class="food-item skeleton" style="height:100rpx;" wx:for="{{[1,2,3,4,5]}}" wx:key="*this"></view>
  </view>

  <!-- 空状态 / 配方推荐 -->
  <view wx:if="{{searchText === '' && activeCategory === ''}}">

    <!-- 场景筛选标签 -->
    <scroll-view class="cat-scroll" scroll-x wx:if="{{recipeScenes.length > 0}}">
      <text class="scene-label">推荐配方</text>
      <view class="cat-tag {{activeScene === item ? 'active' : ''}}"
            wx:for="{{recipeScenes}}" wx:key="*this"
            bindtap="onSceneTap" data-scene="{{item}}">
        {{item}}
      </view>
    </scroll-view>

    <!-- 配方卡片 -->
    <view class="recipe-list">
      <view class="recipe-card card"
            wx:for="{{filteredRecipes}}"
            wx:key="id"
            bindtap="goDetail" data-id="{{item.id}}">
        <!-- 发布者 -->
        <view class="recipe-author" wx:if="{{item.author}}">
          <view class="author-avatar">{{item.author.avatarUrl || '🐱'}}</view>
          <text class="author-name">{{item.author.nickName || '猫友'}}</text>
          <text class="author-date">{{item.createdAt || ''}}</text>
        </view>

        <view class="recipe-header">
          <view class="recipe-title-row">
            <image class="recipe-icon" src="/images/icons/recipe.png" mode="aspectFit"></image>
            <view class="recipe-title-info">
              <text class="recipe-name">{{item.name}}</text>
              <view class="recipe-tags">
                <text class="recipe-scene-tag">{{item.sceneTag || item.scene}}</text>
                <text class="recipe-meta" wx:if="{{item.time}}">⏱ {{item.time}}</text>
                <text class="recipe-meta" wx:if="{{item.difficulty}}">{{item.difficulty}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="recipe-ingredients">
          <text class="ingredient-label">食材：</text>
          <block wx:for="{{item.ingredients}}" wx:for-item="ing" wx:key="name">
            <text class="ingredient-name">{{ing.name}} {{ing.amount}}</text>
            <text wx:if="{{index < item.ingredients.length - 1}}" class="ingredient-plus"> + </text>
          </block>
        </view>
        <view class="recipe-tip" wx:if="{{item.tips}}">
          <image class="tip-icon" src="/images/icons/tips.png" mode="aspectFit"></image>
          <text class="tip-text">{{item.tips}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 无结果 -->
  <view wx:elif="{{noResult}}" class="empty-state">
    <image style="width:80rpx;height:80rpx;" src="/images/icons/search.png" mode="aspectFit"></image>
    <text>未找到匹配的食材</text>
  </view>

  <!-- 搜索结果列表 -->
  <view wx:else class="food-list">
    <view class="food-item card" wx:for="{{results}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="food-info">
        <text class="food-name">{{item.name}}</text>
        <text class="food-cat">{{item.categoryLabel}}</text>
      </view>
      <view class="food-level">
        <text class="{{item.safety === 'safe' ? 'tag-safe' : item.safety === 'caution' ? 'tag-caution' : 'tag-danger'}}">
          {{item.safetyLabel}}
        </text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  </block>
  <!-- ═══ 食物查询模式结束 ═══ -->

  <!-- ═══ 营养知识面板 ═══ -->
  <view class="nutrition-panel" wx:if="{{activeTab === 'nutrition'}}">
    <view class="nutrition-intro">
      <text class="nutrition-intro-text">猫咪是专性肉食动物，以下 13 种核心营养素对它们的健康至关重要。点击查看每种营养素的作用及富含该营养素的食材。</text>
    </view>

    <view class="nutrient-list">
      <view class="nutrient-card card {{selectedNutrientId === item.id ? 'expanded' : ''}}"
            wx:for="{{nutrients}}" wx:key="id"
            bindtap="onNutrientTap" data-id="{{item.id}}">

        <!-- 营养素头部 -->
        <view class="nutrient-header">
          <view class="nutrient-icon">{{item.id === 'nu1' ? '🥩' : item.id === 'nu2' ? '💪' : item.id === 'nu3' ? '🐟' : item.id === 'nu4' ? '🦴' : item.id === 'nu5' ? '⚡' : item.id === 'nu6' ? '❤️' : item.id === 'nu7' ? '🌿' : item.id === 'nu8' ? '🧈' : item.id === 'nu9' ? '👁️' : item.id === 'nu10' ? '🔋' : item.id === 'nu11' ? '🩸' : item.id === 'nu12' ? '🛡️' : '💧'}}</view>
          <view class="nutrient-info">
            <text class="nutrient-name">{{item.name}}</text>
            <text class="nutrient-key">{{item.key}}</text>
          </view>
          <text class="nutrient-arrow">{{selectedNutrientId === item.id ? '▾' : '▸'}}</text>
        </view>

        <!-- 展开详情 -->
        <view class="nutrient-detail" wx:if="{{selectedNutrientId === item.id}}">
          <view class="detail-section">
            <text class="detail-label"><image style="width:24rpx;height:24rpx;vertical-align:middle;margin-right:4rpx;" src="/images/icons/agreement.png" mode="aspectFit"></image>对猫的重要性</text>
            <text class="detail-text">{{item.importance}}</text>
          </view>
          <view class="detail-section" wx:if="{{item.deficiency}}">
            <text class="detail-label"><image style="width:24rpx;height:24rpx;vertical-align:middle;margin-right:4rpx;" src="/images/icons/warning.png" mode="aspectFit"></image>缺乏症状</text>
            <text class="detail-text">{{item.deficiency}}</text>
          </view>
          <view class="detail-section" wx:if="{{item.dailyNeed}}">
            <text class="detail-label">📏 每日需求参考</text>
            <text class="detail-text">{{item.dailyNeed}}</text>
          </view>
          <view class="detail-section">
            <text class="detail-label">🍖 富含此营养素的食物</text>
            <view class="nutrient-foods">
              <text class="nutrient-food-tag" wx:for="{{item.foodIds}}" wx:key="*this" wx:for-item="foodId">
                {{item._foodMap ? item._foodMap[foodId] : foodId}}
              </text>
              <text class="nutrient-food-empty" wx:if="{{item.foodIds.length === 0}}">暂无收录食材</text>
            </view>
          </view>
          <view class="detail-section" wx:if="{{item.note}}">
            <text class="detail-label">💡 小贴士</text>
            <text class="detail-text note-text">{{item.note}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 补充剂 -->
    <view class="supplement-section">
      <view class="section-title"><image style="width:32rpx;height:32rpx;vertical-align:middle;margin-right:6rpx;" src="/images/icons/supplement.png" mode="aspectFit"></image>常用营养补充剂</view>
      <view class="supplement-card card" wx:for="{{supplements}}" wx:key="id">
        <text class="supplement-name">{{item.name}}</text>
        <text class="supplement-type">{{item.type}}</text>
        <text class="supplement-benefit">{{item.benefit}}</text>
        <view class="supplement-advice">
          <text class="detail-label">✅ 使用建议</text>
          <text class="detail-text">{{item.advice}}</text>
        </view>
        <view class="supplement-warning" wx:if="{{item.warning}}">
          <text class="detail-label"><image style="width:24rpx;height:24rpx;vertical-align:middle;margin-right:4rpx;" src="/images/icons/warning.png" mode="aspectFit"></image>注意事项</text>
          <text class="detail-text">{{item.warning}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
