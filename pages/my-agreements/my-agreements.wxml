<!-- 我的领养协议列表 -->
<view class="container">
  <view wx:if="{{loading}}">
    <view class="skeleton" style="height:80rpx;margin-bottom:16rpx;" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
  </view>

  <view wx:elif="{{agreements.length === 0}}" class="empty-state">
    <text style="font-size:80rpx;">📋</text>
    <text>暂无领养协议</text>
    <text style="font-size:24rpx;color:var(--text-secondary);margin-top:12rpx;">下载并签署协议后，在此回传存档</text>
  </view>

  <view wx:else>
    <view class="agreement-item card" wx:for="{{agreements}}" wx:key="id">
      <view>
        <text class="agreement-title">领养协议 #{{index + 1}}</text>
        <text class="agreement-date">{{item.created_at}}</text>
      </view>
      <text class="status">{{item.status === 'completed' ? '✅' : '📝'}}</text>
    </view>
  </view>

  <!-- 胶囊按钮 -->
  <view class="capsule-bar">
    <button class="capsule-btn" bindtap="goUpload">回传已签署协议</button>
  </view>
</view>
