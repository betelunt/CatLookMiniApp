.photo-section { margin-bottom: 30rpx; }
.photo-preview { width: 240rpx; height: 240rpx; border-radius: 16rpx; }
.photo-placeholder {
  width: 240rpx; height: 240rpx; border-radius: 16rpx;
  background: #F0F0F0; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 8rpx;
  color: var(--text-secondary); font-size: 26rpx;
}
.photo-icon { width: 64rpx; height: 64rpx; }

.form-group { margin-bottom: 24rpx; }
.label { font-size: 28rpx; font-weight: 600; color: #555; display: block; margin-bottom: 8rpx; }
.input { background: var(--card); padding: 20rpx 24rpx; border-radius: 12rpx; font-size: 28rpx; }
.textarea { background: var(--card); padding: 20rpx 24rpx; border-radius: 12rpx; font-size: 28rpx; min-height: 120rpx; }
.picker-value { background: var(--card); padding: 20rpx 24rpx; border-radius: 12rpx; font-size: 28rpx; }
.switch-row { display: flex; justify-content: space-between; align-items: center; }
.field-hint { font-size: 22rpx; color: #E67E22; margin-top: 6rpx; display: block; }
.archive-code-display { background: #F8F8F8; padding: 20rpx 24rpx; border-radius: 12rpx; }
.archive-code-value { font-size: 36rpx; font-weight: 700; font-family: monospace; letter-spacing: 4rpx; color: #333; display: block; margin-top: 4rpx; }
