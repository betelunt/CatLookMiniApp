.hero-placeholder {
  width: 100%; height: 400rpx; border-radius: 16rpx;
  background: #FFF5EC; display: flex; align-items: center;
  justify-content: center; font-size: 120rpx; margin-bottom: 20rpx;
}
.hero-photo-wrap {
  position: relative; margin-bottom: 20rpx; border-radius: 16rpx; overflow: hidden;
}
.hero-photo {
  width: 100%; height: 500rpx; background: #F0F0F0; display: block;
}
.photo-zoom-tip {
  position: absolute; bottom: 16rpx; right: 16rpx;
  background: rgba(0,0,0,0.55); color: #FFF;
  padding: 8rpx 20rpx; border-radius: 24rpx;
  font-size: 22rpx; display: flex; align-items: center; gap: 6rpx;
}
.zoom-icon { width: 28rpx; height: 28rpx; }
.name-row { display: flex; align-items: baseline; gap: 16rpx; margin-bottom: 24rpx; }
.cat-name { font-size: 40rpx; font-weight: 700; }
.breed { font-size: 26rpx; color: var(--text-secondary); }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.info-item { display: flex; flex-direction: column; gap: 4rpx; }
.info-label { font-size: 24rpx; color: var(--text-secondary); }
.gender-icon-detail { width: 32rpx; height: 32rpx; }
.section-title { font-size: 28rpx; font-weight: 700; display: block; margin-bottom: 12rpx; }
.detail-archive-code {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-secondary);
  letter-spacing: 3rpx;
  font-family: monospace;
  padding: 12rpx 0;
  margin-bottom: -8rpx;
}
.action-btns { display: flex; gap: 20rpx; margin-top: 20rpx; }
.special-notes-card { background: #FFF7F0; border-left: 6rpx solid #FF8C42; }
.action-btns button { flex: 1; font-size: 28rpx; }
.action-btns.secondary { margin-top: 14rpx; }
.btn-icon { width: 32rpx; height: 32rpx; vertical-align: middle; margin-right: 6rpx; }
