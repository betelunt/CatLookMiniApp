<!-- 黑名单详情页 -->
<view class="container" wx:if="{{!loading}}">

  <!-- 标题 -->
  <view class="section-title">失信人信息</view>

  <!-- 声明 -->
  <view class="disclaimer">
    <image style="width:28rpx;height:28rpx;vertical-align:middle;margin-right:4rpx;" src="/images/icons/warning.png" mode="aspectFit"></image>以下信息真实性由发布者个人承担。如侵犯您的个人权益，请与我们联系。
  </view>

  <!-- 信息表 -->
  <view class="info-card card">
    <view class="info-row" wx:if="{{report.real_name}}">
      <text class="info-label">真实姓名</text>
      <text class="info-value">{{report.real_name}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">性别</text>
      <text class="info-value">{{report.gender === 'male' ? '男' : '女'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">身份</text>
      <text class="info-value role-tag {{report.role}}">{{report.role === 'adopter' ? '领养人' : '送养人'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">所在地</text>
      <text class="info-value"><image style="width:24rpx;height:24rpx;vertical-align:middle;margin-right:2rpx;" src="/images/icons/location.png" mode="aspectFit"></image>{{report.city}}</text>
    </view>
    <view class="info-row" wx:if="{{report.id_number}}">
      <text class="info-label">身份证号</text>
      <text class="info-value blurred">{{report.id_number}}</text>
    </view>
    <view class="info-row" wx:if="{{report.phone}}">
      <text class="info-label">手机号</text>
      <text class="info-value blurred">{{report.phone}}</text>
    </view>
    <view class="info-row" wx:if="{{report.wechat_id}}">
      <text class="info-label">微信号</text>
      <text class="info-value">{{report.wechat_id}}</text>
    </view>
    <view class="info-row" wx:if="{{report.wechat_nickname}}">
      <text class="info-label">微信昵称</text>
      <text class="info-value">{{report.wechat_nickname}}</text>
    </view>
    <view class="info-row" wx:if="{{report.address}}">
      <text class="info-label">详细地址</text>
      <text class="info-value">{{report.address}}</text>
    </view>
  </view>

  <!-- 举报理由 -->
  <view class="section-title">举报理由</view>
  <view class="reason-card card">
    <view class="category-badge">{{report.category}}</view>
    <view class="description-text">{{report.description}}</view>

    <!-- 证据图片 -->
    <view wx:if="{{report.evidence_urls && report.evidence_urls.length > 0}}" class="evidence-grid">
      <image
        wx:for="{{report.evidence_urls}}"
        wx:key="*this"
        class="evidence-img"
        src="{{item}}"
        mode="aspectFill"
        bindtap="previewImage"
        data-url="{{item}}"
      />
    </view>
  </view>

  <!-- 帮忙证实 -->
  <view class="section-title">帮忙证实</view>
  <view class="confirm-card card">
    <!-- 已有证实列表 -->
    <view wx:if="{{report.confirmations && report.confirmations.length > 0}}">
      <view class="confirm-item" wx:for="{{report.confirmations}}" wx:key="name">
        <view class="confirm-avatar">👤</view>
        <view class="confirm-info">
          <text class="confirm-name">{{item.name}}</text>
          <text wx:if="{{item.note}}" class="confirm-note">：{{item.note}}</text>
        </view>
      </view>
    </view>

    <!-- 无人证实 -->
    <view wx:else class="no-confirm">
      <text style="font-size:60rpx;">🤷</text>
      <text>暂无人帮忙证实</text>
      <text style="font-size:24rpx;color:var(--text-secondary);margin-top:8rpx;">如果您了解此事，请帮忙证实</text>
    </view>

    <!-- 证实表单 -->
    <view wx:if="{{showConfirmForm}}" class="confirm-form">
      <input
        class="confirm-input"
        placeholder="您的称呼（必填）"
        value="{{confirmName}}"
        bindinput="onConfirmNameInput"
      />
      <textarea
        class="confirm-textarea"
        placeholder="补充说明（选填）"
        value="{{confirmNote}}"
        bindinput="onConfirmNoteInput"
      />
      <view class="confirm-form-btns">
        <view class="btn-outline" bindtap="onToggleConfirmForm">取消</view>
        <view class="btn-primary" bindtap="onSubmitConfirm" wx:if="{{!confirming}}">提交证实</view>
        <view class="btn-primary disabled" wx:else>提交中...</view>
      </view>
    </view>

    <!-- 证实按钮 -->
    <view wx:else class="confirm-btn-row">
      <button class="btn-primary" bindtap="onToggleConfirmForm">✋ 帮忙证实</button>
      <button class="btn-outline share-detail-btn" open-type="share"><image class="btn-icon" src="/images/icons/share.png" mode="aspectFit"></image> 转发给好友</button>
    </view>
  </view>

</view>

<!-- 加载 -->
<view wx:else class="container">
  <view class="skeleton card" style="height:400rpx;"></view>
</view>
