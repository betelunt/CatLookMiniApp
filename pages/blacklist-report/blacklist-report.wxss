/* 黑名单举报表单 - 3步 */

/* ── 步骤指示器 ── */
.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}
.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.step-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #E0E0E0;
  color: #FFF;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}
.step.active .step-num {
  background: var(--primary);
}
.step.done .step-num {
  background: var(--success);
}
.step-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}
.step.active .step-label {
  color: var(--primary);
  font-weight: 600;
}
.step-line {
  width: 80rpx;
  height: 4rpx;
  background: #E0E0E0;
  margin: 0 16rpx;
  margin-bottom: 20rpx;
}
.step-line.active {
  background: var(--primary);
}

/* ── 表单主体 ── */
.step-body {
  padding-bottom: 40rpx;
}
.form-group {
  margin-bottom: 28rpx;
}
.form-label {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.required { color: var(--danger); font-size: 24rpx; }
.optional { color: var(--text-secondary); font-size: 22rpx; font-weight: 400; }
.form-hint {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.form-input {
  height: 80rpx;
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}
.form-input.picker-val {
  display: flex;
  align-items: center;
  color: var(--text-secondary);
}
.form-textarea {
  width: 100%;
  min-height: 200rpx;
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

/* 双输入 */
.dual-input {
  display: flex;
  gap: 16rpx;
}
.dual-input .half {
  flex: 1;
}

/* ── 单选组 ── */
.radio-group {
  display: flex;
  gap: 20rpx;
}
.radio-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.2s;
}
.radio-item.checked {
  border-color: var(--primary);
  background: #FFF3E8;
  color: var(--primary);
  font-weight: 700;
}

/* ── 分类标签网格 ── */
.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.category-tag {
  padding: 16rpx 28rpx;
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 0.2s;
}
.category-tag.selected {
  border-color: var(--danger);
  background: #FFEBEE;
  color: #C62828;
  font-weight: 700;
}

/* ── 证据上传 ── */
.evidence-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.evidence-preview {
  position: relative;
  width: 156rpx;
  height: 156rpx;
  border-radius: 12rpx;
  overflow: hidden;
}
.preview-img {
  width: 100%;
  height: 100%;
}
.remove-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.6);
  color: #FFF;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 12rpx 0 12rpx;
}
.add-btn {
  width: 156rpx;
  height: 156rpx;
  border-radius: 12rpx;
  border: 3rpx dashed var(--border);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: var(--card);
}

/* ── Step 3 提示 ── */
.contact-notice {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #FFF3E0;
  border-radius: 16rpx;
  padding: 30rpx 24rpx;
  margin-bottom: 30rpx;
  font-size: 26rpx;
  color: #E65100;
  text-align: center;
  line-height: 1.6;
}

.submit-area {
  margin-top: 40rpx;
}
.submit-btn {
  width: 100%;
  padding: 24rpx;
  font-size: 32rpx;
}
.submit-btn.disabled {
  opacity: 0.6;
}

/* ── 底部导航 ── */
.step-nav {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-bottom: 40rpx;
}
.step-nav .btn-primary,
.step-nav .btn-outline {
  flex: 1;
  padding: 20rpx;
  text-align: center;
}
.btn-placeholder {
  flex: 1;
}
