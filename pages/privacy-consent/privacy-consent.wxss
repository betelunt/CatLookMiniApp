/* 隐私协议同意页面 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f8f8f8;
}

/* ── 内容区 ── */
.scroll-area {
  flex: 1;
  padding: 0 20px 20px;
}

.title {
  font-size: 20px;
  font-weight: bold;
  color: #333;
  text-align: center;
  padding: 20px 0 12px;
}

.privacy-text {
  font-size: 14px;
  line-height: 1.8;
  color: #555;
  white-space: pre-line;
  text-align: justify;
}

/* ── 底部固定栏 ── */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1px solid #eee;
  padding: 16px 20px;
  padding-bottom: calc(16px + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 12px;
  z-index: 10;
}

.checkbox-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.checkbox {
  width: 20px;
  height: 20px;
  min-width: 20px;
  border: 2px solid #ccc;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  color: transparent;
  transition: all 0.2s;
}

.checkbox.checked {
  border-color: #FF8C42;
  background: #FF8C42;
  color: #fff;
}

.checkbox-label {
  font-size: 14px;
  color: #333;
}

.link-text {
  color: #FF8C42;
  text-decoration: underline;
}

.btn-agree {
  width: 100%;
  height: 48px;
  border-radius: 24px;
  background: #ccc;
  color: #fff;
  font-size: 16px;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: background 0.2s;
}

.btn-agree.active {
  background: #FF8C42;
}

.btn-disagree {
  text-align: center;
  font-size: 14px;
  color: #999;
  padding: 4px 0;
}
