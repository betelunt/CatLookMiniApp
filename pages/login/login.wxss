.login-container {
  display: flex; align-items: center; justify-content: center;
  min-height: 100vh;
}
.login-card { text-align: center; width: 100%; }
.logo-text { font-size: 120rpx; display: block; margin-bottom: 24rpx; }
.app-name { font-size: 44rpx; font-weight: 700; display: block; margin-bottom: 12rpx; }
.app-desc { font-size: 28rpx; color: var(--text-secondary); display: block; margin-bottom: 60rpx; }
.privacy-notice { font-size: 24rpx; color: var(--text-secondary); margin-bottom: 30rpx; }
.link { color: var(--primary); }
.login-btn { width: 100%; margin-bottom: 20rpx; }
.tip { font-size: 24rpx; color: var(--text-secondary); }
