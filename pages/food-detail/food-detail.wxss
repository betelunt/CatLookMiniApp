/* 食材详情 */
.food-header {
  display: flex; align-items: center; gap: 24rpx; margin-bottom: 24rpx;
}
.food-name { font-size: 40rpx; font-weight: 700; }
.section { margin-bottom: 20rpx; }
.section-title { display: flex; align-items: center; gap: 8rpx; font-size: 30rpx; font-weight: 700; margin-bottom: 12rpx; }
.section-title-icon { width: 34rpx; height: 34rpx; flex-shrink: 0; }
.section-body { font-size: 28rpx; line-height: 1.8; color: #555; }

/* ── 配方详情 ── */

/* 发布者卡片 */
.recipe-author-card {
  display: flex; align-items: center; gap: 16rpx;
}
.author-avatar-lg {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: #FFF3E0; display: flex; align-items: center;
  justify-content: center; font-size: 36rpx; flex-shrink: 0;
}
.author-info { flex: 1; }
.author-nick { font-size: 28rpx; font-weight: 600; display: block; }
.author-date { font-size: 22rpx; color: var(--text-secondary); }
.like-area { display: flex; align-items: center; gap: 6rpx; }
.like-icon { width: 40rpx; height: 40rpx; }
.like-count { font-size: 24rpx; color: var(--text-secondary); }

/* 配方头部 */
.recipe-hero { text-align: center; padding: 32rpx 24rpx; }
.recipe-hero-name { font-size: 38rpx; font-weight: 700; display: block; margin-bottom: 16rpx; }
.recipe-hero-tags { display: flex; justify-content: center; gap: 16rpx; flex-wrap: wrap; }
.recipe-scene-tag {
  background: #FFF3E0; color: #E67E22; font-size: 24rpx;
  padding: 6rpx 20rpx; border-radius: 20rpx;
}
.recipe-meta-tag {
  font-size: 24rpx; color: var(--text-secondary);
}

/* 食材清单 */
.ingredient-list { }
.ingredient-item {
  display: flex; align-items: center; gap: 12rpx;
  padding: 14rpx 0; border-bottom: 1rpx solid #F5F5F5;
}
.ingredient-item:last-child { border-bottom: none; }
.ing-dot { font-size: 28rpx; color: var(--primary); }
.ing-name { font-size: 28rpx; font-weight: 600; flex: 1; }
.ing-amount { font-size: 26rpx; color: var(--text-secondary); }

/* 制作步骤 */
.step-list { }
.step-item {
  display: flex; align-items: flex-start; gap: 16rpx;
  padding: 16rpx 0; border-bottom: 1rpx solid #F5F5F5;
}
.step-item:last-child { border-bottom: none; }
.step-num-lg {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: var(--primary); color: #FFF;
  font-size: 24rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.step-text { font-size: 28rpx; line-height: 1.7; color: #555; flex: 1; }

/* 免责声明 */
.disclaimer-card {
  margin-top: 40rpx; padding: 24rpx;
  background: #FFFDE7; border-radius: 14rpx;
}
.disclaimer-text { font-size: 24rpx; color: #8D6E00; line-height: 1.7; }
