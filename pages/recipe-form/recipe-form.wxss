.form-group { margin-bottom: 24rpx; }
.label {
  font-size: 28rpx; font-weight: 600; color: var(--text);
  display: block; margin-bottom: 10rpx;
}
.input {
  background: var(--card); padding: 18rpx 20rpx;
  border-radius: 12rpx; font-size: 28rpx;
  border: 1rpx solid var(--border);
}
.textarea {
  background: var(--card); padding: 18rpx 20rpx;
  border-radius: 12rpx; font-size: 28rpx; width: 100%;
  min-height: 120rpx; border: 1rpx solid var(--border);
}
.picker-value {
  background: var(--card); padding: 18rpx 20rpx;
  border-radius: 12rpx; font-size: 28rpx;
  color: var(--text-secondary); border: 1rpx solid var(--border);
}

/* 双列布局 */
.form-row { display: flex; gap: 16rpx; }
.form-row .half { flex: 1; }

/* section 头部 */
.section-label {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 12rpx;
}
.add-btn {
  font-size: 24rpx; color: var(--primary); font-weight: 600;
}

/* 食材行 */
.ingredient-row {
  display: flex; align-items: center; gap: 12rpx;
  margin-bottom: 12rpx;
}
.ing-name { flex: 2; }
.ing-amount { flex: 1; }

/* 步骤行 */
.step-row {
  display: flex; align-items: flex-start; gap: 12rpx;
  margin-bottom: 14rpx;
}
.step-num {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: var(--primary); color: #FFF;
  font-size: 24rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-top: 14rpx;
}
.step-input { flex: 1; min-height: 90rpx; }

/* 删除按钮 */
.remove-btn {
  font-size: 32rpx; color: #CCC; flex-shrink: 0;
  padding: 8rpx;
}

/* 免责声明 */
.disclaimer {
  display: flex; gap: 10rpx; padding: 20rpx; margin-bottom: 32rpx;
  background: #FFFDE7; border-radius: 12rpx; border: 1rpx solid #FFF9C4;
}
.disclaimer-icon { font-size: 28rpx; flex-shrink: 0; }
.disclaimer-text { font-size: 22rpx; color: #8D6E00; line-height: 1.6; }
