<!-- 我的猫饭配方 -->
<view class="container">
  <!-- 创建按钮 -->
  <view class="create-bar">
    <button class="btn-primary create-btn" bindtap="goCreate">
      <image style="width:32rpx;height:32rpx;vertical-align:middle;margin-right:6rpx;" src="/images/icons/recipe.png" mode="aspectFit"></image>创建新配方
    </button>
  </view>

  <!-- 加载态 -->
  <view wx:if="{{loading}}">
    <view class="skeleton card" style="height:140rpx;" wx:for="{{[1,2]}}" wx:key="*this"></view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{recipes.length === 0}}" class="empty-state">
    <image style="width:80rpx;height:80rpx;" src="/images/icons/recipe.png" mode="aspectFit"></image>
    <text style="font-size:30rpx;font-weight:600;margin-top:16rpx;">还没有配方</text>
    <text style="margin-top:8rpx;">分享你家猫咪最爱的猫饭吧</text>
  </view>

  <!-- 配方列表 -->
  <view wx:else class="recipe-list">
    <view class="recipe-card card" wx:for="{{recipes}}" wx:key="id">
      <!-- 头部：头像 + 信息 -->
      <view class="rc-header" bindtap="goDetail" data-id="{{item.id}}">
        <view class="rc-avatar">{{item.author.avatarUrl || '🐱'}}</view>
        <view class="rc-info">
          <text class="rc-name">{{item.name}}</text>
          <view class="rc-tags">
            <text class="rc-scene">{{item.sceneTag || item.scene}}</text>
            <text class="rc-meta" wx:if="{{item.time}}">⏱ {{item.time}}</text>
          </view>
        </view>
      </view>

      <!-- 食材预览 -->
      <view class="rc-ingredients" bindtap="goDetail" data-id="{{item.id}}">
        <block wx:for="{{item.ingredients}}" wx:for-item="ing" wx:key="name">
          <text class="ing-item">{{ing.name}}</text>
        </block>
      </view>

      <!-- 底部：时间 + 操作 -->
      <view class="rc-footer">
        <text class="rc-date">{{item.createdAt || ''}}</text>
        <view class="rc-actions">
          <view class="rc-action" bindtap="goEdit" data-id="{{item.id}}">
            <image class="rc-action-icon" src="/images/icons/edit.png" mode="aspectFit"></image>
            <text>编辑</text>
          </view>
          <view class="rc-action delete" bindtap="onDelete" data-id="{{item.id}}">
            <image class="rc-action-icon" src="/images/icons/clear.png" mode="aspectFit"></image>
            <text>删除</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
