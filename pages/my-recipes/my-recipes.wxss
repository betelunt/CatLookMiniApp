.create-bar { margin-bottom: 24rpx; }
.create-btn { width: 100%; }

.recipe-card { padding: 24rpx; margin-bottom: 20rpx; }

/* 头部 */
.rc-header {
  display: flex; align-items: center; gap: 16rpx;
  margin-bottom: 16rpx;
}
.rc-avatar {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: #FFF3E0; display: flex; align-items: center;
  justify-content: center; font-size: 32rpx; flex-shrink: 0;
}
.rc-info { flex: 1; }
.rc-name {
  font-size: 30rpx; font-weight: 700; color: var(--text);
  display: block; margin-bottom: 6rpx;
}
.rc-tags { display: flex; align-items: center; gap: 16rpx; }
.rc-scene {
  font-size: 22rpx; background: #FFF3E0;
  color: #E67E22; padding: 4rpx 12rpx; border-radius: 20rpx;
}
.rc-meta { font-size: 22rpx; color: var(--text-secondary); }

/* 食材 */
.rc-ingredients {
  display: flex; flex-wrap: wrap; gap: 10rpx;
  margin-bottom: 16rpx; padding: 12rpx;
  background: #F9F9F9; border-radius: 10rpx;
}
.ing-item {
  font-size: 22rpx; color: var(--text-secondary);
  background: #FFF; padding: 4rpx 14rpx;
  border-radius: 20rpx; border: 1rpx solid #EEE;
}

/* 底部 */
.rc-footer {
  display: flex; justify-content: space-between; align-items: center;
}
.rc-date { font-size: 22rpx; color: #CCC; }
.rc-actions { display: flex; gap: 24rpx; }
.rc-action { display: flex; align-items: center; gap: 6rpx; font-size: 24rpx; color: var(--primary); }
.rc-action-icon { width: 32rpx; height: 32rpx; }
.rc-action.delete { color: #CCC; }
